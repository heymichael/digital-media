# Local development configuration

# Local Postgres (Docker)
DATABASE_URL=postgresql://media_local:localdev@localhost:5437/digital_media_local

# GCS bucket prefix (org slug is appended)
GCS_BUCKET_PREFIX=haderach-media

# Vertex AI project
VERTEX_PROJECT=haderach-ai
VERTEX_LOCATION=us-central1

# Dev auth bypass (local only, never set in production)
DEV_AUTH_EMAIL=dev@haderach.ai

# Google Cloud credentials for local development
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
